# ============================================
# Glow Studio by Sofia — Variables de Entorno
# ============================================
# Copia este archivo como .env.local y rellena los valores reales.

# --- BASE DE DATOS (NEON) ---
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST/neondb?sslmode=require"

# --- META DEVELOPER: WHATSAPP (Notificaciones al dueño) ---
WHATSAPP_PHONE_ID="tu_phone_id_de_meta"
WHATSAPP_TOKEN="tu_token_permanente_de_meta"
WEBHOOK_VERIFY_TOKEN="un_token_secreto_que_tu_inventes"
SALON_WHATSAPP="5491155554444"

# --- META DEVELOPER: INSTAGRAM (Chatbot de atención al cliente) ---
META_PAGE_ACCESS_TOKEN="tu_page_access_token_de_meta"
META_VERIFY_TOKEN="mismo_valor_que_WEBHOOK_VERIFY_TOKEN"

# --- GOOGLE CALENDAR (Sincronización de citas) ---
GOOGLE_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
GOOGLE_CALENDAR_ID="tu_email@gmail.com"

# --- GEMINI AI (Motor de inteligencia artificial) ---
GEMINI_API_KEY="tu_api_key_de_google_ai_studio"

# --- SERVIDORES (Producción - Render) ---
BOT_URL="https://glow-studio-bot.onrender.com"
FRONTEND_URL="https://tu-dominio.vercel.app"

